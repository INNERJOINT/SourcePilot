# ─── Embedding 服务配置 ───────────────────────────────
EMBEDDING_MODEL=microsoft/unixcoder-base
EMBEDDING_DIM=768
EMBEDDING_PORT=8080

# ─── Qdrant 配置 ─────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── 索引构建配置（build_index.sh 使用）──────────────
# ZOEKT_URL=http://localhost:6070
# DENSE_COLLECTION_NAME=aosp_code

# CODE_EMBEDDING_MODEL: which code-embedding model to load at server boot.
# Valid values: nomic-ai/CodeRankEmbed (default), microsoft/unixcoder-base
# bge-base-zh-v1.5 (Chinese auxiliary) is always loaded regardless.
# Switching requires server restart AND a project that uses a matching collection.
CODE_EMBEDDING_MODEL=nomic-ai/CodeRankEmbed
