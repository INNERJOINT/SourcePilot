# ═══════════════════════════════════════════════════════
#  AOSP Code Search 环境配置模板
#
#  用法：复制为 .env 并修改需要的值
#    cp .env.example .env
#
#  语法说明：
#    KEY=VALUE            普通赋值
#    KEY="quoted value"   引号会被自动去除
#    export KEY=VALUE     export 前缀会被自动忽略
#    # 注释               整行注释
#    KEY=value # 注释      行内注释会被自动去除
#
#  注意：不支持多行值、变量插值（$VAR）
#  命令行传入的环境变量始终优先于 .env 中的值
# ═══════════════════════════════════════════════════════

# ─── Zoekt 配置 ──────────────────────────────────────
# Zoekt webserver 地址
ZOEKT_URL=http://localhost:6070
# Zoekt 索引目录（run_all.sh 启动 sparse-index-zoekt 时使用）
ZOEKT_INDEX_PATH=/mnt/code/ACE/.repo/.zoekt/

# ─── 多项目配置 ───────────────────────────────────────
# 项目注册表路径（YAML 格式，定义每个 AOSP checkout 的 zoekt 端口和索引目录）
# run_all_dev.sh 会为每个项目启动独立的 zoekt-webserver 进程
# 留空或文件不存在时退回单项目模式（使用 ZOEKT_INDEX_PATH + ZOEKT_URL）
PROJECTS_CONFIG_PATH=config/projects.yaml

# ─── 索引容器源码挂载 ────────────────────────────────
# dense/graph 索引容器（deploy/docker-compose.yml 的 indexer profile）
# 会把该目录以只读方式挂到容器内 /src。wrapper 脚本把宿主机路径翻译为
# /src/<subpath> 后传给容器内的 build_*_index.py。
# 注意：scripts/build_dense_index_batch.sh 中的 AOSP_ROOT 默认值应与此保持一致。
AOSP_SOURCE_ROOT=/mnt/code/ACE

# ─── Zoekt Docker 配置 ────────────────────────────────
# Docker 模式下的仓库路径（bind mount 到 indexserver）
# ZOEKT_REPO_PATH=/mnt/code/ACE/.repo
# Docker 模式下的 zoekt 端口映射
# ZOEKT_PORT=6070

# ─── SourcePilot 配置 ────────────────────────────────
# 搜索结果上下文窗口：命中行上下各取多少行
# DEFAULT_CONTEXT_LINES=20
# 是否启用 BM25 评分
# USE_BM25_SCORING=true
# Zoekt 服务端返回的上下文行数
# NUM_CONTEXT_LINES=3

# ─── Gateway 容器配置 ────────────────────────────────
# Gateway 容器宿主机端口映射（compose 模式）
SOURCEPILOT_PORT=9000
# 构建 gateway 镜像时是否安装 qdrant-client（启用 dense 通道时设为 true）
GATEWAY_INSTALL_DENSE=false

# ─── 自然语言增强（NL）配置 ────────────────────────────
NL_ENABLED=true
NL_MODEL=CVTE-AUTO
NL_API_KEY=your-nl-api-key-here
NL_API_BASE=https://navimaxx-cc.test.seewo.com/v1
# NL 请求超时（秒）
# NL_TIMEOUT=10.0
# NL 缓存 TTL（秒）
# NL_CACHE_TTL=86400

# ─── Dense 向量检索配置 ────────────────────────────────
# 是否启用 dense（语义向量）搜索通道
DENSE_ENABLED=false
# Qdrant 向量数据库地址
# DENSE_VECTOR_DB_URL=http://localhost:6333
# Qdrant collection 名称
# DENSE_COLLECTION_NAME=aosp_code
# Embedding 服务地址
# DENSE_EMBEDDING_URL=http://localhost:8080/v1
# Embedding 模型名
# DENSE_EMBEDDING_MODEL=unixcoder-base
# Embedding 维度
# DENSE_EMBEDDING_DIM=768
# Dense 返回条数
# DENSE_TOP_K=20
# Dense 结果在 rerank 中的加分
# DENSE_RERANK_BOOST=0.05

# ─── ONNX Embedding Server 配置 ────────────────────────
# OMP_NUM_THREADS=18
# EMBEDDING_MAX_BATCH_SIZE=64
# Per-corpus embedding model (used by gateway for model routing)
# DENSE_EMBEDDING_MODEL_CODE=nomic-ai/CodeRankEmbed
# DENSE_EMBEDDING_MODEL_ZH=BAAI/bge-base-zh-v1.5

# ─── MCP Server 配置 ──────────────────────────────────
# 传输模式：streamable-http 或 stdio（run_all.sh 使用）
MCP_TRANSPORT=streamable-http
# MCP 监听端口（streamable-http 模式）
MCP_PORT=8888
# MCP Bearer Token 鉴权（留空则不鉴权）
# MCP_AUTH_TOKEN=your-mcp-auth-token-here

# ─── 审计日志配置 ──────────────────────────────────────
# 审计日志总开关
# AUDIT_ENABLED=true
# 慢查询阈值（毫秒）
# AUDIT_SLOW_QUERY_MS=3000
# 审计日志文件路径（必须为绝对路径或可被多个进程一致解析的相对路径）
# SourcePilot 写入此文件，sp-cockpit 通过 SP_COCKPIT_AUDIT_LOG_PATH 读取同一文件
# 留空时由 run_sourcepilot.sh / run_sp_cockpit.sh 锚定到项目根目录的 audit.log
# AUDIT_LOG_FILE=./audit.log
# sp-cockpit 读取的日志路径（应与 AUDIT_LOG_FILE 相同）
# SP_COCKPIT_AUDIT_LOG_PATH=./audit.log
# sp-cockpit SQLite 镜像数据库路径（默认 sp-cockpit/data/audit.db）
# SP_COCKPIT_AUDIT_DB_PATH=./sp-cockpit/data/audit.db
# sp-cockpit 服务监听端口 / 主机
# SP_COCKPIT_PORT=9100
# SP_COCKPIT_HOST=0.0.0.0
# 周期性摘要间隔（秒），0 表示禁用
# AUDIT_SUMMARY_INTERVAL=300

# ─── Indexing Admin 配置 ───────────────────────────────
# 索引管理 API 内部鉴权 Token（wrapper 脚本与 sp-cockpit 共享此值）
# 生产环境请替换为足够长的随机字符串
INDEXING_INTERNAL_TOKEN=change-me-to-random-token

# ─── Graph 检索配置 ────────────────────────────────────
# 是否启用图谱（Neo4j）检索通道
# GRAPH_ENABLED=false
# Neo4j Bolt 连接地址
# GRAPH_NEO4J_URI=bolt://localhost:7687
# Neo4j 用户名
# GRAPH_NEO4J_USER=neo4j
# Neo4j 密码
# GRAPH_NEO4J_PASSWORD=sourcepilot
# Graph 检索通道超时（毫秒）
# GRAPH_LANE_TIMEOUT_MS=2000

