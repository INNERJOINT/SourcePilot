# AOSP Project Registry
# Copy this file to config/projects.yaml and edit paths.
# Backend scope is parsed by scripts/indexing/project_config.py.
projects:
  - name: ace
    source_root: /mnt/code/ACE
    repo_path: /mnt/code/ACE/.repo
    collection_name: aosp_code_ace

    # Sparse (Zoekt) backend configuration.
    # Precedence: sparse_index.index_dir > top-level index_dir > default
    # Precedence: sparse_index.zoekt_url > top-level zoekt_url > default
    sparse_index:
      index_dir: /mnt/code/ACE/.repo/.zoekt
      zoekt_url: http://localhost:6070
      include:
        - frameworks/base

    # Dense collection precedence:
    #   1. dense_index.collection_name
    #   2. collection_name
    #   3. aosp_code_{name}
    dense_index:
      # enabled: false
      # include: []  # explicit disable
      collection_name: aosp_code_ace_dense
      include:
        - frameworks/base

    # Graph identity uses (project, repo, path) and displays repo/path.
    graph_index:
      # enabled: false
      # include: []  # explicit disable
      include:
        - frameworks/base

    # Legacy shared scope example (do not combine with backend-specific include):
    # sub_project_globs:
    #   - frameworks/base

  - name: aosp15
    source_root: /mnt/code/AOSP15

# Feishu Lurk knowledge base — dense-only project (no Zoekt backend).
# Vectors live in a Milvus collection with Feishu document schema.
# Feishu collection fields: title, url, space_id, node_token, content
# - name: feishu_lurk
#   project_type: feishu
#   zoekt_url: ""
#   dense_index:
#     collection_name: feishu_lurk_docs
